# 🤖 Telegram Bot Configuration
BOT_TOKEN=your_bot_token_from_botfather

# ⚙️ Scraper Credentials
LOGIN=your_site_login
PASSWORD=your_site_password

# 🌐 Proxy Configuration (Optional if not using custom ones)
# PROXY_URL is handled automatically by the 'proxy' service in docker-compose.yml
# But you can set it here if you want to bypass the internal proxy
# PROXY_URL=http://your-proxy-address:port
